      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{FE2D7DE5-A1F8-4007-9603-36810E753D55}"
          SQLTask:SqlStatementSource="MERGE Customer_Dim AS [Target]&#xA;USING Stage_Customer AS Source&#xA;ON (Target.Customer_BK = Source.Customer_id) -- Match on Natural Key&#xA;&#xA;WHEN NOT MATCHED BY TARGET THEN&#xA;    -- Insert new record&#xA;    INSERT (Customer_BK, First_Name, Last_Name, Email)&#xA;    VALUES (Source.Customer_id, Source.First_Name, Source.Last_Name, Source.Email);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
